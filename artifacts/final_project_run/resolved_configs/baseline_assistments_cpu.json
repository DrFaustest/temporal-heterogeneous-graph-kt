{
  "run": {
    "name": "phase12_baseline_assistments",
    "notes": "Baseline end-to-end smoke run on the ASSISTments fixture"
  },
  "dataset": {
    "name": "assistments_fixture",
    "relation_mode": "none"
  },
  "preprocessing": {
    "min_interactions_per_student": 4,
    "drop_interactions_without_concepts": true
  },
  "split": {
    "strategy": "student_chronological",
    "train_ratio": 0.5,
    "val_ratio": 0.25,
    "test_ratio": 0.25,
    "random_seed": 42
  },
  "graph": {
    "interaction_edge_split": "train",
    "include_student_exposure_edges": true,
    "include_reverse_edges": false
  },
  "model": {
    "type": "logistic_baseline"
  },
  "training": {
    "epochs": 2,
    "batch_size": 2,
    "learning_rate": 0.1,
    "device": "cpu",
    "random_seed": 42
  }
}