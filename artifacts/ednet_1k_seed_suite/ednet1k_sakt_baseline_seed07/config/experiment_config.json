{
  "dataset": {
    "contents_path": "data/raw/ednet/contents",
    "max_users": 1000,
    "name": "ednet_path",
    "path": "data/raw/ednet/KT1",
    "relation_mode": "transition"
  },
  "explainability": {
    "enabled": false
  },
  "graph": {
    "include_reverse_edges": false,
    "include_student_exposure_edges": true,
    "interaction_edge_split": "train"
  },
  "model": {
    "attempt_count_scale": 5.0,
    "attention_heads": 4,
    "dropout": 0.1,
    "elapsed_time_scale": 5000.0,
    "gradient_clip_norm": 5.0,
    "hidden_dim": 64,
    "type": "sakt_baseline"
  },
  "preprocessing": {
    "drop_interactions_without_concepts": true,
    "min_interactions_per_student": 4
  },
  "run": {
    "name": "ednet1k_sakt_baseline_seed07"
  },
  "sequence": {
    "max_history_length": 128
  },
  "split": {
    "random_seed": 7,
    "strategy": "student_chronological",
    "test_ratio": 0.15,
    "train_ratio": 0.7,
    "val_ratio": 0.15
  },
  "training": {
    "batch_size": 32,
    "device": "cuda",
    "early_stopping_patience": 3,
    "epochs": 20,
    "learning_rate": 0.001,
    "random_seed": 7
  }
}